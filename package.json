{
  "name": "claude-launcher",
  "version": "0.3.0",
  "description": "Windows GUI for managing Claude Code sessions with split-screen terminal dashboard",
  "author": "LaunchPad AI <hello@launchpad-ai.dev>",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "lucide-solid": "^0.460.0",
    "node-pty": "^1.1.0",
    "solid-js": "^1.9.0",
    "xterm": "^5.3.0"
  },
  "build": {
    "appId": "com.launchpad-ai.claude-launcher",
    "productName": "Claude Launcher",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.0",
    "@testing-library/jest-dom": "^6.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  }
}
